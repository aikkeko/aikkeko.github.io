# Cloudflare R2 配置
# 复制此文件为 .env 并填写实际值

# ============================================
# 方案 A：提供完整的 R2 端点（推荐）
# 格式：https://<account_id>.r2.cloudflarestorage.com/<bucket_name>
# 示例：https://78aeb471b834893423e4e0a7a5499914.r2.cloudflarestorage.com/aikkeko
# ============================================
R2_ENDPOINT=https://78aeb471b834893423e4e0a7a5499914.r2.cloudflarestorage.com/aikkeko

# ============================================
# 方案 B：分别提供 Account ID 和 Bucket 名称
# 如果上面的 R2_ENDPOINT 已设置，以下配置可选
# ============================================

# Cloudflare Account ID
# 在 Cloudflare Dashboard 右上角可以找到
R2_ACCOUNT_ID=78aeb471b834893423e4e0a7a5499914

# R2 Bucket 名称
R2_BUCKET_NAME=aikkeko

# R2 Access Key ID
# 在 R2 管理页面创建 API Token 时获得
R2_ACCESS_KEY_ID=your_access_key_here

# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=your_secret_key_here

# ============================================
# 公开访问配置（必需）
# ============================================

# R2 公开访问 URL
# 用于替换文档中的图片链接
# 如果有自定义域名：R2_PUBLIC_URL=https://cdn.yoursite.com
# 如果使用 R2 原生域名（路径式）：R2_PUBLIC_URL=https://<account_id>.r2.cloudflarestorage.com/<bucket>
R2_PUBLIC_URL=https://78aeb471b834893423e4e0a7a5499914.r2.cloudflarestorage.com/aikkeko

# 上传路径前缀
# 最终路径将是：https://<public_url>/<prefix>/2026/03/filename.png
R2_UPLOAD_PREFIX=blog
