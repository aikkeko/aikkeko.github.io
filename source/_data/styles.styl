// ============================================
// 35. Whole-site polish pass - readable first, then atmosphere
// ============================================
@keyframes zatoPageReveal {
  from {
    opacity: 0.001;
    transform: translateY(10px);
    filter: blur(4px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
}

// NexT motion can leave normal pages at opacity: 0 when the animation
// pipeline is interrupted. Content must never disappear, so provide a
// defensive visible state and let our lighter reveal handle the polish.
.container.use-motion {
  .post-block,
  .post-header,
  .post-body,
  .collection-header,
  .pagination,
  .comments {
    opacity: 1 !important;
  }
}

.page .post-block,
.archive .post-block,
.tag .post-block,
.category .post-block,
.post .post-block {
  animation: zatoPageReveal 0.46s ease both;
  will-change: opacity, transform;
}

@media (prefers-reduced-motion: reduce) {
  .page .post-block,
  .archive .post-block,
  .tag .post-block,
  .category .post-block,
  .post .post-block {
    animation: none;
  }
}

