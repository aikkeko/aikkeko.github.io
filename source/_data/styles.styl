      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(212, 196, 168, 0.18);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.7em;
      line-height: 1;
      pointer-events: none;
    }

    &:hover {
      transform: translateX(8px);
      border-color: rgba(212, 196, 168, 0.28);
      background:
        linear-gradient(135deg, rgba(65, 67, 73, 0.66), rgba(26, 29, 36, 0.48));
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);

      &::before {
        background: #d4c4a8;
      }
    }
  }

  .posts-collapse .post-meta {
    display: block;
    margin: 0;
    color: #d4c4a8;
    font-size: 0.82em;

    time {
      display: inline-flex;
      justify-content: center;
      min-width: 58px;
      padding: 5px 8px;
      border: 1px solid rgba(212, 196, 168, 0.2);
      background: rgba(16, 18, 22, 0.34);
      letter-spacing: 0.06em;
    }
  }

  .posts-collapse .post-title {
    display: block;
    padding-right: 48px;
    font-size: 1.05em;

    a,
    span.exturl {
      color: #e8e4dc;
      background-image: linear-gradient(90deg, rgba(212, 196, 168, 0.55), rgba(106, 160, 154, 0.38));
      background-position: 0 100%;
      background-repeat: no-repeat;
      background-size: 0 1px;
      transition:
        color 0.2s ease,
        background-size 0.24s ease;

      &:hover {
        color: #fff8ea;
        background-size: 100% 1px;
      }
    }
  }
}

@media (max-width: 768px) {
  .archive {
    .archive-hero {
      margin: -2px 0 32px;
      padding: 28px 22px 24px;

      &::before {
        position: static;
        display: block;
        margin-bottom: 12px;
      }
    }

    .archive-hero-title {
      font-size: 1.85em;
    }

    .archive-hero-stats span {
      font-size: 0.72em;
    }

    .posts-collapse {
      padding-left: 38px;
      margin-left: 0;
      margin-right: 0;

      &::before {
        left: 16px;
      }
    }

    .collection-title::before,
    .collection-year::before,
    .posts-collapse .post-header::before {
      left: -28px;
    }

    .posts-collapse .post-header {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 14px 16px;
    }

    .posts-collapse .post-title {
      padding-right: 30px;
    }
  }
}

// ============================================
// 28. Homepage title refinement - quieter literary masthead
// ============================================
.index {
  .site-title-main {
    background: none !important;
    -webkit-background-clip: initial !important;
    background-clip: initial !important;
    color: #f7efe2 !important;
    filter: none !important;
    font-family:
      "Noto Serif SC",
      "Source Han Serif SC",
      "Songti SC",
      "SimSun",
      serif;
    font-size: clamp(3rem, 4.25vw, 4.15rem);
    font-weight: 600;
    line-height: 1.14;
    letter-spacing: 0.02em !important;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08),
      0 3px 8px rgba(0, 0, 0, 0.88),
      0 14px 34px rgba(0, 0, 0, 0.62),
      0 0 18px rgba(212, 196, 168, 0.18) !important;
  }

  .hero-text {
    &::before {
      content: '';
      position: absolute;
      left: 50%;
      top: 58%;
      width: unquote('min(640px, 78vw)');
      height: 44%;
      transform: translate(-50%, -50%);
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(ellipse at center, rgba(8, 10, 14, 0.46), rgba(8, 10, 14, 0) 68%);
      filter: blur(6px);
    }
  }

  .site-subtitle-main {
    color: rgba(232, 220, 198, 0.92);
    font-size: 1.28em;
    letter-spacing: 0.06em;
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.9),
      0 0 16px rgba(212, 196, 168, 0.2);
  }

  .hero-kicker {
    color: rgba(232, 228, 220, 0.84);
  }
}

@media (max-width: 768px) {
  .index {
    .site-title-main {
      font-size: clamp(2.25rem, 10.5vw, 2.85rem);
      line-height: 1.18;
      letter-spacing: 0 !important;
    }

    .site-subtitle-main {
      font-size: 0.92em;
      letter-spacing: 0.03em;
    }
  }
}

// ============================================
// 29. About & tag pages - refined archive cabinets
// ============================================
.page-identity-hero {
  position: relative;
  overflow: hidden;
  margin: -6px -12px 34px;
  padding: 34px 38px 32px;
  border: 1px solid rgba(212, 196, 168, 0.2);
  background:
    linear-gradient(135deg, rgba(212, 196, 168, 0.14), rgba(28, 31, 38, 0.34) 46%, rgba(106, 160, 154, 0.1)),
    radial-gradient(circle at 76% 20%, rgba(212, 196, 168, 0.14), transparent 30%),
    repeating-linear-gradient(90deg, transparent 0, transparent 13px, rgba(255, 255, 255, 0.026) 13px, rgba(255, 255, 255, 0.026) 14px);
  box-shadow:
    0 22px 60px rgba(0, 0, 0, 0.3),
    0 0 0 1px rgba(255, 255, 255, 0.035) inset;

  &::before {
    content: 'Z.A.T.O / CUSTOMER ARCHIVE';
    position: absolute;
    right: 28px;
    top: 22px;
    color: rgba(212, 196, 168, 0.3);
    font-size: 0.68em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  &::after {
    content: '';
    position: absolute;
    left: 30px;
    right: 30px;
    bottom: 0;
    height: 1px;
    background:
      linear-gradient(90deg, rgba(212, 196, 168, 0.68), rgba(106, 160, 154, 0.38), transparent);
  }
}

.tag-index-hero::before {
  content: 'Z.A.T.O / TAG DIRECTORY';
}

.tag-detail-hero::before {
  content: 'Z.A.T.O / FILTERED SHELF';
}

.page-hero-kicker {
  color: rgba(106, 160, 154, 0.94);
  font-size: 0.74em;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.page-hero-title {
  margin: 9px 0 10px;
  color: #fff8ea;
  font-family:
    "Noto Serif SC",
    "Source Han Serif SC",
    "Songti SC",
    "SimSun",
    serif;
  font-size: 2.35em;
  font-weight: 600;
  line-height: 1.14;
  letter-spacing: 0.01em;
  text-shadow:
    0 10px 28px rgba(0, 0, 0, 0.56),
    0 0 22px rgba(212, 196, 168, 0.18);
}

.page-hero-desc {
  max-width: 42em;
  margin: 0;
  color: rgba(232, 228, 220, 0.76);
  line-height: 1.75;
}

.page-hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 22px;

  span {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    padding: 7px 11px;
    color: rgba(232, 228, 220, 0.72);
    border: 1px solid rgba(212, 196, 168, 0.17);
    background:
      linear-gradient(135deg, rgba(17, 19, 24, 0.46), rgba(35, 38, 45, 0.28));
    font-size: 0.8em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  strong {
    color: #d4c4a8;
    font-size: 1.12em;
    letter-spacing: 0;
  }
}

.about-content-panel {
  display: grid;
  grid-template-columns: minmax(180px, 0.32fr) minmax(0, 1fr);
  gap: 26px;
  align-items: start;
}

.about-profile-card {
  position: sticky;
  top: 88px;
  padding: 22px 20px;
  border: 1px solid rgba(212, 196, 168, 0.18);
  background:
    linear-gradient(145deg, rgba(212, 196, 168, 0.12), rgba(18, 20, 26, 0.34)),
    repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.028) 0, rgba(255, 255, 255, 0.028) 1px, transparent 1px, transparent 9px);
  box-shadow:
    0 18px 38px rgba(0, 0, 0, 0.24),
    0 0 0 1px rgba(255, 255, 255, 0.026) inset;

  &::before {
    content: '';
    display: block;
    width: 46px;
    height: 46px;
    margin-bottom: 16px;
    border: 1px solid rgba(212, 196, 168, 0.5);
    background:
      radial-gradient(circle at 50% 50%, rgba(212, 196, 168, 0.95) 0 3px, transparent 4px),
      linear-gradient(135deg, rgba(106, 160, 154, 0.22), rgba(212, 196, 168, 0.12));
    box-shadow:
      0 0 0 6px rgba(212, 196, 168, 0.05),
      0 0 24px rgba(212, 196, 168, 0.18);
  }

  .about-profile-label {
    display: block;
    margin-bottom: 9px;
    color: rgba(106, 160, 154, 0.9);
    font-size: 0.68em;
    letter-spacing: 0.2em;
  }

  strong {
    display: block;
    color: #fff8ea;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.42em;
    font-weight: 500;
    line-height: 1.2;
  }

  em {
    display: block;
    margin-top: 10px;
    color: rgba(232, 228, 220, 0.66);
    font-style: normal;
    line-height: 1.55;
  }
}

.about-prose {
  min-width: 0;
  padding: 4px 0 0;

  p {
    color: rgba(232, 228, 220, 0.78);
    font-size: 1.03em;
    line-height: 1.9;
  }

  center {
    display: block;
    margin: 26px 0 0;
    color: #d4c4a8;
    font-family:
      "Noto Serif SC",
      "Source Han Serif SC",
      "Songti SC",
      "SimSun",
      serif;
    font-size: 1.06em;
    letter-spacing: 0.03em;
    text-shadow: 0 0 18px rgba(212, 196, 168, 0.12);
  }
}

.tag-index-panel {
  position: relative;
  padding: 26px 24px 30px;
  border: 1px solid rgba(212, 196, 168, 0.16);
  background:
    linear-gradient(145deg, rgba(28, 31, 38, 0.52), rgba(15, 17, 22, 0.28)),
    radial-gradient(circle at 15% 0%, rgba(106, 160, 154, 0.08), transparent 28%);

  &::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(212, 196, 168, 0.065);
    pointer-events: none;
  }

  .tag-cloud-title {
    margin-bottom: 22px;
    color: rgba(232, 228, 220, 0.76);
    font-size: 0.88em;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .tag-cloud-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    line-height: 1.5;
  }

  .tag-cloud-tags a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 7px 13px;
    border: 1px solid rgba(212, 196, 168, 0.16);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgba(212, 196, 168, 0.09), rgba(18, 20, 26, 0.28));
    color: rgba(232, 228, 220, 0.78) !important;
    font-size: 0.95em !important;
    letter-spacing: 0.02em;
    text-decoration: none;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.12);

    &::before {
      content: '#';
      margin-right: 5px;
      color: rgba(106, 160, 154, 0.86);
      font-size: 0.86em;
    }

    &:hover {
      transform: translateY(-2px);
      border-color: rgba(212, 196, 168, 0.38);
      color: #fff8ea !important;
      background:
        linear-gradient(135deg, rgba(212, 196, 168, 0.18), rgba(106, 160, 154, 0.1));
      box-shadow:
        0 14px 30px rgba(0, 0, 0, 0.22),
        0 0 20px rgba(212, 196, 168, 0.1);
    }
  }
}

.tag {
  .tag-detail-hero {
    margin-bottom: 30px;
  }

  .collection-title {
    display: none;
  }

  .collection-year {
    margin: 42px 0 22px;

    &::before {
      left: -34px;
      width: 17px;
      height: 17px;
      margin-left: 0;
      border-color: rgba(212, 196, 168, 0.72);
      background:
        radial-gradient(circle, #d4c4a8 0 3px, #1e2128 4px);
      box-shadow:
        0 0 0 5px rgba(212, 196, 168, 0.08),
        0 0 22px rgba(212, 196, 168, 0.2);
    }

    .collection-header {
      display: inline-flex;
      margin-left: 0;
      padding: 4px 12px 5px;
      color: #fff8ea;
      border: 1px solid rgba(212, 196, 168, 0.2);
      background:
        linear-gradient(135deg, rgba(212, 196, 168, 0.13), rgba(18, 20, 26, 0.24));
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.32em;
      line-height: 1.2;
      letter-spacing: 0.04em;
    }
  }

  .posts-collapse {
    margin-left: 0;
    padding-left: 58px;

    &::before {
      left: 24px;
      background:
        linear-gradient(180deg, transparent, rgba(212, 196, 168, 0.58) 12%, rgba(106, 160, 154, 0.3) 58%, transparent);
    }
  }

  .posts-collapse .post-header {
    display: grid;
    grid-template-columns: 74px minmax(0, 1fr);
    align-items: center;
    gap: 18px;
    margin: 13px 0;
    padding: 13px 16px;
    border: 1px solid rgba(212, 196, 168, 0.1);
    border-bottom: 1px solid rgba(212, 196, 168, 0.1);
    background:
      linear-gradient(135deg, rgba(49, 51, 57, 0.5), rgba(24, 27, 34, 0.36));
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      background 0.24s ease;

    &::before {
      left: -38px;
      width: 10px;
      height: 10px;
      margin-left: 0;
      border-color: rgba(212, 196, 168, 0.54);
      background: #1e2128;
    }

    &:hover {
      transform: translateX(7px);
      border-color: rgba(212, 196, 168, 0.28);
      background:
        linear-gradient(135deg, rgba(65, 67, 73, 0.62), rgba(26, 29, 36, 0.46));
    }
  }

  .posts-collapse .post-meta {
    display: block;
    margin: 0;

    time {
      display: inline-flex;
      justify-content: center;
      min-width: 58px;
      padding: 5px 8px;
      border: 1px solid rgba(212, 196, 168, 0.2);
      background: rgba(16, 18, 22, 0.34);
      color: #d4c4a8;
      letter-spacing: 0.06em;
    }
  }

  .posts-collapse .post-title {
    font-size: 1.04em;

    a,
    span.exturl {
      color: #e8e4dc;
      background-image: linear-gradient(90deg, rgba(212, 196, 168, 0.55), rgba(106, 160, 154, 0.38));
      background-position: 0 100%;
      background-repeat: no-repeat;
      background-size: 0 1px;
      transition:
        color 0.2s ease,
        background-size 0.24s ease;

      &:hover {
        color: #fff8ea;
        background-size: 100% 1px;
      }
    }
  }
}

@media (max-width: 768px) {
  .page-identity-hero {
    margin: -2px 0 30px;
    padding: 28px 22px 24px;

    &::before {
      position: static;
      display: block;
      margin-bottom: 12px;
    }
  }

  .page-hero-title {
    font-size: 1.86em;
  }

  .page-hero-stats span {
    font-size: 0.72em;
  }

  .about-content-panel {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .about-profile-card {
    position: relative;
    top: auto;
  }

  .tag-index-panel {
    padding: 22px 18px 24px;

    .tag-cloud-tags {
      gap: 9px;
    }

    .tag-cloud-tags a {
      min-height: 33px;
      padding: 6px 11px;
      font-size: 0.88em !important;
    }
  }

  .tag {
    .posts-collapse {
      padding-left: 38px;
    }

    .collection-title::before,
    .posts-collapse .post-header::before {
      left: -28px;
    }

    .posts-collapse .post-header {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 14px 16px;
    }
  }
}
