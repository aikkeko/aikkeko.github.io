// ============================================
// 30. Z.A.T.O background maxims - faded archive signage
// ============================================
.zato-background-quotes {
  position: fixed;
  inset: 0;
  z-index: 1;
  overflow: hidden;
  pointer-events: none;
  user-select: none;
  mix-blend-mode: screen;
}

.zato-quote {
  position: absolute;
  display: block;
  color: rgba(232, 228, 220, 0.28);
  font-family:
    "Times New Roman",
    Georgia,
    "Noto Serif SC",
    serif;
  font-size: clamp(0.66rem, 0.72vw, 0.86rem);
  font-weight: 500;
  line-height: 1;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  white-space: nowrap;
  text-shadow:
    0 0 14px rgba(212, 196, 168, 0.18),
    0 2px 8px rgba(0, 0, 0, 0.78);
  opacity: 0.54;
  filter: blur(0.15px);

  &::before,
  &::after {
    content: '';
    display: inline-block;
    width: 34px;
    height: 1px;
    margin: 0 12px 0 0;
    vertical-align: middle;
    background: linear-gradient(90deg, transparent, rgba(212, 196, 168, 0.38));
  }

  &::after {
    margin: 0 0 0 12px;
    background: linear-gradient(90deg, rgba(212, 196, 168, 0.38), transparent);
  }
}

.zato-quote-left {
  left: unquote('max(320px, 27vw)');
  top: 19vh;
  transform: rotate(90deg);
  transform-origin: left top;
  color: rgba(106, 160, 154, 0.32);
  opacity: 0.44;
}

.zato-quote-right {
  right: 5.2vw;
  top: 68vh;
  transform: rotate(90deg);
  transform-origin: right top;
  color: rgba(232, 228, 220, 0.24);
  opacity: 0.5;
}

.zato-quote-top {
  left: 49vw;
  top: 5.4vh;
  transform: translateX(-50%);
  color: rgba(212, 196, 168, 0.28);
  opacity: 0.48;
}

.zato-quote-mid {
  left: 44vw;
  top: 42vh;
  transform: rotate(-7deg);
  color: rgba(232, 228, 220, 0.18);
  font-size: clamp(0.58rem, 0.66vw, 0.76rem);
  letter-spacing: 0.24em;
  opacity: 0.34;
}

.zato-quote-bottom {
  right: 9vw;
  bottom: 12vh;
  transform: rotate(-2deg);
  color: rgba(212, 196, 168, 0.24);
  opacity: 0.42;
}

.zato-quote-code {
  left: 56vw;
  bottom: 25vh;
  padding: 6px 9px;
  border: 1px solid rgba(212, 196, 168, 0.12);
  background: rgba(8, 10, 14, 0.12);
  color: rgba(106, 160, 154, 0.28);
  font-family:
    "Courier New",
    Consolas,
    monospace;
  font-size: clamp(0.54rem, 0.62vw, 0.72rem);
  letter-spacing: 0.16em;
  opacity: 0.52;

  &::before,
  &::after {
    width: 16px;
  }
}

.header,
.main,
.footer {
  position: relative;
  z-index: 2;
