      transform 0.24s ease,
      border-color 0.24s ease,
      background 0.24s ease,
      box-shadow 0.24s ease;

    &::before {
      left: -43px;
      top: 50%;
      width: 10px;
      height: 10px;
      margin-left: 0;
      margin-top: -5px;
