// ============================================
// 31. Homepage subtitle entrance - archival lightbox reveal
// ============================================
.index {
  .hero-subtitle-reveal {
    position: relative;
    display: inline-block;
    overflow: hidden;
    padding: 0.12em 0.42em 0.18em;
    color: rgba(232, 220, 198, 0.94) !important;
    background:
      linear-gradient(90deg, transparent, rgba(8, 10, 14, 0.18) 18%, rgba(8, 10, 14, 0.18) 82%, transparent);
    clip-path: inset(0 100% 0 0);
    opacity: 0;
    filter: blur(5px);
    transform: translateY(12px) scale(0.985);
    animation:
      archiveSubtitleReveal 1.35s cubic-bezier(0.18, 0.72, 0.22, 1) 0.72s forwards,
      archiveSubtitleSettle 2.8s ease 1.35s forwards;

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      transform: translateX(-115%);
      background:
        linear-gradient(90deg, transparent, rgba(255, 248, 234, 0.46) 46%, rgba(106, 160, 154, 0.18) 54%, transparent);
      mix-blend-mode: screen;
      pointer-events: none;
      animation: archiveSubtitleScan 1.55s cubic-bezier(0.2, 0.8, 0.2, 1) 0.82s forwards;
    }

    &::after {
      content: '';
      position: absolute;
      left: 0.42em;
      right: 0.42em;
      bottom: 0;
      height: 1px;
      margin-left: 0;
      background:
        linear-gradient(90deg, transparent, rgba(212, 196, 168, 0.74), rgba(106, 160, 154, 0.34), transparent);
      opacity: 0;
      animation: archiveSubtitleRule 1.1s ease 1.3s forwards;
    }
  }
}

@keyframes archiveSubtitleReveal {
  0% {
    clip-path: inset(0 100% 0 0);
    opacity: 0;
    filter: blur(5px);
    transform: translateY(12px) scale(0.985);
    letter-spacing: 0.14em;
  }
  58% {
    opacity: 0.76;
    filter: blur(2px);
  }
  100% {
    clip-path: inset(0 0 0 0);
    opacity: 1;
    filter: blur(0);
    transform: translateY(0) scale(1);
    letter-spacing: 0.06em;
  }
}

@keyframes archiveSubtitleScan {
  0% {
    transform: translateX(-115%);
    opacity: 0;
  }
  24% {
    opacity: 0.88;
  }
  100% {
    transform: translateX(115%);
    opacity: 0;
  }
}

@keyframes archiveSubtitleRule {
  from {
    opacity: 0;
    transform: scaleX(0.18);
  }
  to {
    opacity: 0.68;
    transform: scaleX(1);
  }
}

@keyframes archiveSubtitleSettle {
  from {
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.9),
      0 0 22px rgba(212, 196, 168, 0.34);
  }
  to {
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.88),
      0 0 14px rgba(212, 196, 168, 0.2);
  }
}

@media (prefers-reduced-motion: reduce) {
  .index {
    .hero-subtitle-reveal {
      clip-path: none !important;
      opacity: 1 !important;
      filter: none !important;
      transform: none !important;
      animation: none !important;

      &::before {
        display: none;
      }

      &::after {
        opacity: 0.58;
        animation: none !important;
      }
    }
  }
}

@media (max-width: 768px) {
  .index {
    .hero-subtitle-reveal {
      padding-inline: 0.2em;
      animation-delay: 0.48s, 1.1s;
    }
  }
}

