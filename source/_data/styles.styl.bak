body {
 	background:url(/images/background2.png);
 	background-repeat: no-repeat;
    background-attachment:fixed;
    background-position:50% 50%;
	background-size: cover; 
}

 h2, h3, h4, h5, h6 {
  border-bottom: 2px solid #8c8c8c;
  padding: 0 5% 2px 0;
}

//修改页脚文字
.footer {
  color: $fontColor;
  font-size: 10px;
  +mobile() {
    font-size: 6px;
  }
  .busuanzi-value {
    font-weight: bold;
  }
}