// Post Banner Styles - Elegant hero image design
// Designed to match Gemini theme aesthetic

// Post page banner (article detail page)
.post-banner {
  position: relative;
  width: 100%;
  height: 340px;
  margin: 0 0 30px 0;
  background: no-repeat center center;
  background-size: cover;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  
  +tablet-mobile() {
    height: 220px;
    margin: 0 0 20px 0;
    border-radius: 6px;
  }
}

.post-banner-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(0, 0, 0, 0.3) 50%,
    rgba(0, 0, 0, 0.6) 100%
  );
  z-index: 1;
}

.post-banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 2;
  padding: 35px 40px;
  color: #fff;
  
  +tablet-mobile() {
    padding: 20px 25px;
  }
}

.post-banner-title {
  font-size: 2.2em;
  font-weight: 600;
  margin: 0 0 15px 0;
  line-height: 1.4;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  letter-spacing: 0.5px;
  
  +tablet-mobile() {
    font-size: 1.5em;
    margin-bottom: 10px;
  }
}

.post-banner-meta {
  font-size: 0.85em;
  opacity: 0.95;
  font-weight: 400;
  
  span {
    margin-right: 18px;
    display: inline-block;
    
    i {
      margin-right: 5px;
      font-size: 0.9em;
      opacity: 0.85;
      width: 14px;
      text-align: center;
    }
    
    &:last-child {
      margin-right: 0;
    }
  }
  
  +tablet-mobile() {
    font-size: 0.75em;
    
    span {
      margin-right: 12px;
      margin-bottom: 4px;
    }
  }
}

// Adjust post content when banner is present
.posts-expand.post .post-block {
  margin-top: 0;
  padding-top: 0;
}

.posts-expand.post .post-header.banner-hidden {
  display: none;
}

.posts-expand.post .post-header .banner-meta-only {
  display: none;
}

// Hide the old hero image styles when banner is used
.posts-expand.post .post-hero {
  display: none;
}

// Index page hero (compact version for post list)
.posts-expand .post-hero {
  position: relative;
  width: 100%;
  height: 240px;
  overflow: hidden;
  margin-bottom: 20px;
  border-radius: 6px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  transition: box-shadow 0.3s ease, transform 0.3s ease;
  
  &:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }
  
  +tablet-mobile() {
    height: 180px;
  }
}

.post-hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.5s ease;
}

.post-hero:hover .post-hero-image {
  transform: scale(1.05);
}

.post-hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 40%, transparent 100%);
  pointer-events: none;
}

.post-hero-link {
  display: block;
  width: 100%;
  height: 100%;
}

.posts-expand .post-header.with-hero {
  margin-top: 0;
}

// Print styles - hide banner when printing
@media print {
  .post-banner {
    display: none;
  }
  
  .posts-expand.post .post-header.banner-hidden {
    display: block;
    
    .post-title {
      display: block !important;
    }
  }
}
