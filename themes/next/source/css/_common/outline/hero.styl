// Hero Section - Full screen landing
.hero-section {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  background: no-repeat center center;
  background-size: cover;
  background-attachment: fixed;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -$header-height;
  
  +mobile() {
    min-height: 500px;
    background-attachment: scroll;
  }
}

.hero-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: #fff;
  padding: 0 20px 60px 20px;
}

.site-title-main {
  font-size: 4em;
  font-weight: 700;
  margin: 0 0 20px 0;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  letter-spacing: 2px;
  
  +tablet-mobile() {
    font-size: 2.5em;
  }
}

.site-subtitle-main {
  font-size: 1.4em;
  font-weight: 300;
  margin: 0;
  opacity: 0.9;
  min-height: 1.4em;
  text-shadow: 0 1px 5px rgba(0, 0, 0, 0.5);
  
  +tablet-mobile() {
    font-size: 1.1em;
  }
}

.scroll-down {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  font-size: 2em;
  opacity: 0.8;
  animation: bounce 2s infinite;
  cursor: pointer;
  text-decoration: none;
  z-index: 10;
  
  &:hover {
    opacity: 1;
    color: #fff;
  }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  40% {
    transform: translateX(-50%) translateY(-10px);
  }
  60% {
    transform: translateX(-50%) translateY(-5px);
  }
}

// Posts Section
.posts-section {
  padding: 60px 0;
  background: $body-bg-color;
}

.posts-container {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 20px;
}

// Post Card
.post-card {
  display: flex;
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 30px;
  box-shadow: 0 2px 15px rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  
  &:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 25px rgba(0, 0, 0, 0.12);
  }
  
  +tablet-mobile() {
    flex-direction: column;
  }
}

.post-card-image {
  flex: 0 0 280px;
  overflow: hidden;
  
  +tablet-mobile() {
    flex: none;
    height: 200px;
  }
  
  a {
    display: block;
    width: 100%;
    height: 100%;
  }
  
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  &:hover img {
    transform: scale(1.05);
  }
}

.post-card-content {
  flex: 1;
  padding: 25px 30px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  
  +tablet-mobile() {
    padding: 20px;
  }
}

.post-card-title {
  font-size: 1.4em;
  font-weight: 600;
  margin: 0 0 15px 0;
  line-height: 1.4;
  
  a {
    color: $text-color;
    border-bottom: none;
    
    &:hover {
      color: var(--link-hover-color);
    }
  }
}

.post-card-excerpt {
  color: $grey-dark;
  font-size: 0.95em;
  line-height: 1.7;
  margin-bottom: 20px;
  flex: 1;
}

.post-card-meta {
  font-size: 0.85em;
  color: $grey;
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  
  .post-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    
    i {
      font-size: 0.9em;
    }
    
    a {
      color: $grey;
      border-bottom: none;
      
      &:hover {
        color: var(--link-hover-color);
      }
    }
  }
  
  .tag-separator {
    color: $grey;
  }
}

// Hide sidebar on index page
.index {
  .sidebar {
    display: none;
  }
  
  .content-wrap {
    width: 100%;
    float: none;
  }
}
